---
import Default from '@astrojs/starlight/components/PageTitle.astro';
---

{/*
	Agent-facing directive — rendered inside <main> immediately before the
	page H1 so crawlers and AI agents pick up the canonical index reference
	at the very top of the converted content. Visually hidden via .sr-only.
	See https://afdocs.dev.
*/}
<blockquote class="afdocs-llms-directive sr-only">
	<p>
		For the complete documentation index, see <a href="/llms.txt">llms.txt</a>.
		The full corpus is available at <a href="/llms-full.txt">llms-full.txt</a>.
		This page is also available as Markdown by appending <code>.md</code> to the URL.
	</p>
</blockquote>

<Default><slot /></Default>
